# ────────── DuckSay 配置模板 ──────────
# 复制此文件为 .env 并填入真实值

# Ollama（本地模型）
OLLAMA_URL=http://host.docker.internal:11434/v1
OLLAMA_API_KEY=

# OpenClaw（云端模型）
CLAW_URL=http://127.0.0.1:18789
CLAW_API_KEY=your_claw_api_key_here

# 云端动态密钥（回退值，实际由 rotate-secret.sh 轮换）
CLOUD_AUTH_KEY=

# PostgreSQL
POSTGRES_PASSWORD=change_this_to_a_strong_password
DATABASE_URL=postgresql://duck:${POSTGRES_PASSWORD}@127.0.0.1:5432/duck

# 安全
TRUST_FORWARDED_HEADERS=1
COOKIE_SECURE=0
ALLOWED_ORIGINS=

# 限流
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW=60

# 对话合并（秒）
CONVERSATION_IDLE_SECONDS=1800

# 超时
REQUEST_TIMEOUT=60
